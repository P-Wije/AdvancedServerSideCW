# --- Server ---
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Database ---
# Path is relative to the working directory. Tests override this to ./data/test.sqlite via cross-env.
DB_PATH=./data/alumni-influencers.sqlite

# --- Sessions ---
# CRITICAL: replace in production. Sessions are stored in data/sessions.sqlite.
SESSION_SECRET=replace-with-a-long-random-session-secret
SESSION_MAX_AGE_MINUTES=30

# --- Registration policy ---
# Both alumni and university_staff registrations must end with this domain.
UNIVERSITY_EMAIL_DOMAIN=eastminster.ac.uk

# --- Email (verification + password reset + bid notifications) ---
# Leave SMTP_HOST blank to fall back to the JSON transport that prints the
# rendered emails to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="University of Eastminster <no-reply@eastminster.ac.uk>"

# --- HTTP / CORS / proxy ---
CLIENT_ORIGIN=http://localhost:3000
# Set to true when running behind nginx/load balancer so X-Forwarded-* is honoured.
TRUST_PROXY=false

# --- Uploads ---
UPLOAD_MAX_MB=5
