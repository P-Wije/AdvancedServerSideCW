            "header": [{ "key": "Authorization", "value": "Bearer {{analyticsBearer}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/alumni?format=csv",
              "host": ["{{baseUrl}}"],
              "path": ["api", "alumni"],
              "query": [{ "key": "format", "value": "csv" }]
            }
          }
        }
      ]
    },
    {
      "name": "API Key Scoping Demo",
      "description": "Demonstrates the rubric requirement: an Analytics Dashboard key cannot access the AR endpoint and vice versa. Each request below should return 403 with a `missing` array except the matched request which returns 200.",
      "item": [
        {
          "name": "Analytics token hitting AR endpoint (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{analyticsBearer}}" }],
            "url": { "raw": "{{baseUrl}}/api/public/featured/today", "host": ["{{baseUrl}}"], "path": ["api", "public", "featured", "today"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 403 because token lacks read:alumni_of_day', function () {",
                  "  pm.response.to.have.status(403);",
                  "  pm.expect(pm.response.json().missing).to.include('read:alumni_of_day');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "AR token hitting Analytics endpoint (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{arBearer}}" }],
            "url": { "raw": "{{baseUrl}}/api/analytics/summary", "host": ["{{baseUrl}}"], "path": ["api", "analytics", "summary"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 403 because token lacks read:analytics', function () {",
                  "  pm.response.to.have.status(403);",
                  "  pm.expect(pm.response.json().missing).to.include('read:analytics');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "AR token hitting AR endpoint (expect 200 or 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{arBearer}}" }],
            "url": { "raw": "{{baseUrl}}/api/public/featured/today", "host": ["{{baseUrl}}"], "path": ["api", "public", "featured", "today"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Scope satisfied (200 or 404 if no slot is active)', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
