                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.apiKey) {",
                  "  pm.environment.set('apiBearer', data.apiKey.token || '');",
                  "  pm.environment.set('apiKeyId', String(data.apiKey.id || ''));",
