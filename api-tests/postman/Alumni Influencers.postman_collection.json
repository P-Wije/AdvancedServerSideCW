    {
      "name": "Analytics Dashboard",
      "description": "Bearer-token endpoints used by the University Analytics Dashboard. All require an API key holding the `read:analytics` scope (preset client = analytics_dashboard). Set {{analyticsBearer}} from the Developer > Create API Key request after selecting that preset.",
      "item": [
        {
          "name": "Summary KPIs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{analyticsBearer}}" }],
