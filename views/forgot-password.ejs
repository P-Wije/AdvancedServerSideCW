<section class="card narrow">
  <h1>Reset your password</h1>
  <% if (sent) { %>
    <p>If an account exists for that address, a password reset email is on its way. Check the server console output if SMTP is not configured locally.</p>
    <p class="muted small"><a href="/login">Back to sign in</a></p>
  <% } else { %>
    <p class="muted">We'll send you a link to reset your password.</p>
    <form method="post" action="/forgot-password" class="stack">
      <%- include('partials/csrf') %>
      <label class="field">
        <span>Email</span>
        <input type="email" name="email" required value="<%= formValues.email || '' %>">
      </label>
      <button type="submit" class="primary-button">Send reset email</button>
    </form>
  <% } %>
</section>
