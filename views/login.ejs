<section class="card narrow">
  <h1>Sign in</h1>
  <p class="muted">Use your University of Eastminster email address.</p>
  <% if (errors.find(e => e.field === 'general')) { %>
    <div class="alert alert-error"><%= errors.find(e => e.field === 'general').message %></div>
  <% } %>
  <form method="post" action="/login" class="stack">
    <%- include('partials/csrf') %>
    <input type="hidden" name="next" value="<%= next %>">
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" required value="<%= formValues.email || '' %>" autocomplete="username">
    </label>
    <label class="field">
      <span>Password</span>
      <input type="password" name="password" required autocomplete="current-password">
    </label>
    <button type="submit" class="primary-button">Sign in</button>
  </form>
  <p class="muted small"><a href="/forgot-password">Forgot your password?</a></p>
  <p class="muted small">No account? <a href="/register">Register here</a>.</p>
</section>
