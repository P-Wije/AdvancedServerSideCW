<!DOCTYPE html>
<html>
<head>
    <title>Edit Profile - Alumni Influencers</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <script>
        function addField(containerId, template) {
            const container = document.getElementById(containerId);
            const newField = document.createElement('div');
            newField.innerHTML = template;
            container.appendChild(newField);
        }
    </script>
</head>
<body>
    <h1>Edit Your Profile</h1>
    <form action="/profile" method="POST" enctype="multipart/form-data">
        <h2>Personal Information</h2>
        <label>First Name: <input type="text" name="firstName" value="<%= profile ? profile.firstName : '' %>" required></label><br>
        <label>Last Name: <input type="text" name="lastName" value="<%= profile ? profile.lastName : '' %>" required></label><br>
        <label>Biography: <textarea name="biography" required><%= profile ? profile.biography : '' %></textarea></label><br>
        <label>LinkedIn URL: <input type="url" name="linkedinUrl" value="<%= profile ? profile.linkedinUrl : '' %>" required></label><br>
        <label>Profile Image: <input type="file" name="profileImage" accept="image/*"></label><br>
        <% if (profile && profile.profileImage) { %>
            <img src="<%= profile.profileImage %>" alt="Profile Image" width="100"><br>
        <% } %>

        <h2>Degrees</h2>
        <div id="degrees">
            <% if (profile && profile.degrees) { %>
                <% profile.degrees.forEach(degree => { %>
                    <div>
                        <input type="text" name="degreeTitles" value="<%= degree.title %>" placeholder="Degree Title" required>
                        <input type="url" name="degreeUrls" value="<%= degree.url %>" placeholder="Degree URL" required>
                        <input type="date" name="degreeDates" value="<%= degree.completionDate.toISOString().split('T')[0] %>" required>
                    </div>
                <% }); %>
            <% } %>
        </div>
        <button type="button" onclick="addField('degrees', '<input type=\"text\" name=\"degreeTitles\" placeholder=\"Degree Title\" required> <input type=\"url\" name=\"degreeUrls\" placeholder=\"Degree URL\" required> <input type=\"date\" name=\"degreeDates\" required>')">Add Degree</button>

        <h2>Professional Certifications</h2>
        <div id="certifications">
            <% if (profile && profile.certifications) { %>
                <% profile.certifications.forEach(cert => { %>
                    <div>
                        <input type="text" name="certTitles" value="<%= cert.title %>" placeholder="Certification Title" required>
                        <input type="url" name="certUrls" value="<%= cert.url %>" placeholder="Certification URL" required>
                        <input type="date" name="certDates" value="<%= cert.completionDate.toISOString().split('T')[0] %>" required>
                    </div>
                <% }); %>
            <% } %>
        </div>
        <button type="button" onclick="addField('certifications', '<input type=\"text\" name=\"certTitles\" placeholder=\"Certification Title\" required> <input type=\"url\" name=\"certUrls\" placeholder=\"Certification URL\" required> <input type=\"date\" name=\"certDates\" required>')">Add Certification</button>

        <h2>Professional Licences</h2>
        <div id="licences">
            <% if (profile && profile.licences) { %>
                <% profile.licences.forEach(licence => { %>
                    <div>
                        <input type="text" name="licenceTitles" value="<%= licence.title %>" placeholder="Licence Title" required>
                        <input type="url" name="licenceUrls" value="<%= licence.url %>" placeholder="Licence URL" required>
                        <input type="date" name="licenceDates" value="<%= licence.completionDate.toISOString().split('T')[0] %>" required>
                    </div>
                <% }); %>
            <% } %>
        </div>
        <button type="button" onclick="addField('licences', '<input type=\"text\" name=\"licenceTitles\" placeholder=\"Licence Title\" required> <input type=\"url\" name=\"licenceUrls\" placeholder=\"Licence URL\" required> <input type=\"date\" name=\"licenceDates\" required>')">Add Licence</button>

        <h2>Short Professional Courses</h2>
        <div id="courses">
            <% if (profile && profile.courses) { %>
                <% profile.courses.forEach(course => { %>
                    <div>
                        <input type="text" name="courseTitles" value="<%= course.title %>" placeholder="Course Title" required>
                        <input type="url" name="courseUrls" value="<%= course.url %>" placeholder="Course URL" required>
                        <input type="date" name="courseDates" value="<%= course.completionDate.toISOString().split('T')[0] %>" required>
                    </div>
                <% }); %>
            <% } %>
        </div>
        <button type="button" onclick="addField('courses', '<input type=\"text\" name=\"courseTitles\" placeholder=\"Course Title\" required> <input type=\"url\" name=\"courseUrls\" placeholder=\"Course URL\" required> <input type=\"date\" name=\"courseDates\" required>')">Add Course</button>

        <h2>Employment History</h2>
        <div id="employment">
            <% if (profile && profile.employmentHistory) { %>
                <% profile.employmentHistory.forEach(job => { %>
                    <div>
                        <input type="text" name="positions" value="<%= job.position %>" placeholder="Position" required>
                        <input type="text" name="companies" value="<%= job.company %>" placeholder="Company" required>
                        <input type="date" name="startDates" value="<%= job.startDate.toISOString().split('T')[0] %>" required>
                        <input type="date" name="endDates" value="<%= job.endDate ? job.endDate.toISOString().split('T')[0] : '' %>" placeholder="End Date (leave blank if current)">
                    </div>
                <% }); %>
            <% } %>
        </div>
        <button type="button" onclick="addField('employment', '<input type=\"text\" name=\"positions\" placeholder=\"Position\" required> <input type=\"text\" name=\"companies\" placeholder=\"Company\" required> <input type=\"date\" name=\"startDates\" required> <input type=\"date\" name=\"endDates\" placeholder=\"End Date\">')">Add Employment</button>

        <br><br>
        <button type="submit">Save Profile</button>
    </form>
    <br>
    <a href="/bidding">Go to Bidding</a> | <a href="/auth/logout">Logout</a>
</body>
</html>
